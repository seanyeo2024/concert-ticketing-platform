{
  "rabbit_version": "3.12.0",
  "vhosts": [{ "name": "/" }],
  "users": [
    {
      "name": "ctms",
      "password": "ctms",
      "tags": "administrator"
    }
  ],
  "permissions": [
    { "user": "ctms", "vhost": "/", "configure": ".*", "write": ".*", "read": ".*" }
  ],
  "exchanges": [
    {
      "name": "ctms_topic",
      "vhost": "/",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "queues": [
    { "name": "ticket.purchased",       "vhost": "/", "durable": true, "auto_delete": false, "arguments": {} },
    { "name": "ticket.resale.listed",   "vhost": "/", "durable": true, "auto_delete": false, "arguments": {} },
    { "name": "ticket.resale.sold",     "vhost": "/", "durable": true, "auto_delete": false, "arguments": {} },
    { "name": "concert.cancelled",      "vhost": "/", "durable": true, "auto_delete": false, "arguments": {} },
    { "name": "queue.window.granted",   "vhost": "/", "durable": true, "auto_delete": false, "arguments": {} },
    { "name": "queue.window.expired",   "vhost": "/", "durable": true, "auto_delete": false, "arguments": {} }
  ],
  "bindings": [
    { "source": "ctms_topic", "vhost": "/", "destination": "ticket.purchased",     "destination_type": "queue", "routing_key": "ticket.purchased",     "arguments": {} },
    { "source": "ctms_topic", "vhost": "/", "destination": "ticket.resale.listed", "destination_type": "queue", "routing_key": "ticket.resale.listed",  "arguments": {} },
    { "source": "ctms_topic", "vhost": "/", "destination": "ticket.resale.sold",   "destination_type": "queue", "routing_key": "ticket.resale.sold",    "arguments": {} },
    { "source": "ctms_topic", "vhost": "/", "destination": "concert.cancelled",    "destination_type": "queue", "routing_key": "concert.cancelled",     "arguments": {} },
    { "source": "ctms_topic", "vhost": "/", "destination": "queue.window.granted", "destination_type": "queue", "routing_key": "queue.window.granted",  "arguments": {} },
    { "source": "ctms_topic", "vhost": "/", "destination": "queue.window.expired", "destination_type": "queue", "routing_key": "queue.window.expired",  "arguments": {} }
  ]
}
