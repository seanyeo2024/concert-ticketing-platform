# ── Concert Service (OutSystems) ─────────────────────────────────────────────
CONCERT_SERVICE_URL=https://<your-env>.outsystemscloud.com/ConcertAPI/rest/v1

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=ctms_user
MYSQL_PASSWORD=ctms_pass

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=ctms
RABBITMQ_PASSWORD=ctms_pass
RABBITMQ_EXCHANGE=ctms_topic

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=REPLACE_ME
TWILIO_AUTH_TOKEN=REPLACE_ME
TWILIO_FROM_NUMBER=+1234567890

# ── Email (SendGrid or SMTP) ──────────────────────────────────────────────────
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG.REPLACE_ME
EMAIL_FROM=no-reply@ctms.local

# ── Service ports ─────────────────────────────────────────────────────────────
PRICING_PORT=5001
QUEUE_PORT=5002
TICKET_INVENTORY_PORT=5003
PAYMENT_PORT=5004
QR_PORT=5005
NOTIFICATION_PORT=5006
PURCHASE_WINDOW_PORT=5010
RESALE_PURCHASE_PORT=5011
CONCERT_CANCELLATION_PORT=5012

# ── QR HMAC secret ───────────────────────────────────────────────────────────
QR_HMAC_SECRET=REPLACE_WITH_RANDOM_32_CHAR_STRING

# ── Purchase window duration (seconds) ───────────────────────────────────────
PURCHASE_WINDOW_SECONDS=600
